{
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.jetjams.net/jetjams/v1/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://api.jetjams.net/uploads/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
